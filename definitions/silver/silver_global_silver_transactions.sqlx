    SAFE_CAST(last_update_dt AS TIMESTAMP) AS `updated_at`,
    'EGY' AS `_source_region`,
    'oracle_payments_egy' AS `_source_system`,
    'bronze_egy.transactions' AS `_source_table`,
    CURRENT_TIMESTAMP() AS `_processed_at`,
    CAST(NULL AS STRING) AS `_batch_id`
  FROM ${ref("bronze_egy", "transactions")}
),
-- source[1]: bronze_ksa.transactions (KSA)
source_1 AS (
  SELECT
    CAST(NULL AS STRING) AS `approval_code`,
    CAST(NULL AS STRING) AS `auth_code`,
    TRIM(CAST(authorization_code AS STRING)) AS `authorization_code`,
    TRIM(CAST(payment_channel AS STRING)) AS `channel`,
    TRIM(CAST(currency_code AS STRING)) AS `currency`,
    TRIM(CAST(customer_id AS STRING)) AS `customer_id`,
    ROUND(SAFE_CAST(fee_amount AS NUMERIC), 2) AS `fee_amount`,
    TRIM(CAST(merchant_id AS STRING)) AS `merchant_id`,
    TRIM(CAST(payment_method AS STRING)) AS `payment_method`,
    ROUND(SAFE_CAST(amount AS NUMERIC), 2) AS `txn_amount`,
    TRIM(CAST(transaction_id AS STRING)) AS `txn_id`,
    TRIM(CAST(status AS STRING)) AS `txn_status`,
    SAFE_CAST(created_at AS TIMESTAMP) AS `txn_timestamp`,
