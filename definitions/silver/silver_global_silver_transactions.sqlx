    'bronze_ksa.transactions' AS `_source_table`,
    CURRENT_TIMESTAMP() AS `_processed_at`,
    CAST(NULL AS STRING) AS `_batch_id`
  FROM ${ref("bronze_ksa", "transactions")}
),
-- source[2]: bronze_uae.transactions (UAE)
source_2 AS (
  SELECT
    CAST(NULL AS STRING) AS `approval_code`,
    TRIM(CAST(auth_code AS STRING)) AS `auth_code`,
    CAST(NULL AS STRING) AS `authorization_code`,
    TRIM(CAST(channel AS STRING)) AS `channel`,
    TRIM(CAST(currency AS STRING)) AS `currency`,
    TRIM(CAST(customer_code AS STRING)) AS `customer_id`,
    ROUND(SAFE_CAST(charges AS NUMERIC), 2) AS `fee_amount`,
    TRIM(CAST(merchant_code AS STRING)) AS `merchant_id`,
    TRIM(CAST(payment_method AS STRING)) AS `payment_method`,
    ROUND(SAFE_CAST(txn_amount AS NUMERIC), 2) AS `txn_amount`,
    TRIM(CAST(txn_id AS STRING)) AS `txn_id`,
    TRIM(CAST(payment_status AS STRING)) AS `txn_status`,
    SAFE_CAST(created_dt AS TIMESTAMP) AS `txn_timestamp`,
    SAFE_CAST(modified_at AS TIMESTAMP) AS `updated_at`,
    'UAE' AS `_source_region`,
    'sqlserver_payments_uae' AS `_source_system`,
    'bronze_uae.transactions' AS `_source_table`,
    CURRENT_TIMESTAMP() AS `_processed_at`,
    CAST(NULL AS STRING) AS `_batch_id`
  FROM ${ref("bronze_uae", "transactions")}
)
, unioned AS (
  SELECT * FROM source_0 UNION ALL
  SELECT * FROM source_1 UNION ALL
  SELECT * FROM source_2
)
-- Deduplication logic: Retains only the most recent record per primary key.
-- This resolves potential duplicates resulting from historical snapshots or temporal overlap in sources.
, ranked AS (
  SELECT
    *,
    ROW_NUMBER() OVER (
      PARTITION BY `_source_region`, `_source_system`, `txn_id`
      ORDER BY `updated_at` DESC
    ) AS `_row_number`
  FROM unioned
)
SELECT
  `approval_code`,
  `auth_code`,
  `authorization_code`,
  `channel`,
  `currency`,
  `customer_id`,
  `fee_amount`,
  `merchant_id`,
  `payment_method`,
  `txn_amount`,
  `txn_id`,
  `txn_status`,
  `txn_timestamp`,
  `updated_at`,
  `_source_region`,
  `_source_system`,
  `_source_table`,
  `_processed_at`,
  `_batch_id`
FROM ranked
WHERE `_row_number` = 1
  AND `txn_id` IS NOT NULL
